APP_NAME=PieceWorks
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Karachi
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pieceworks_db
DB_USERNAME=root
DB_PASSWORD=

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@pieceworks.local
MAIL_FROM_NAME="${APP_NAME}"

# ── Sanctum / Frontend ────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000
FRONTEND_URL=http://localhost:3000

# ── EOBI Integration ──────────────────────────────────────────────────────────
# Credentials for submitting monthly EOBI challani to the EOBI portal
EOBI_PORTAL_URL=https://portal.eobi.gov.pk
EOBI_EMPLOYER_CODE=
EOBI_USERNAME=
EOBI_PASSWORD=

# ── PayEdge Payroll Integration ───────────────────────────────────────────────
# Used to push net settlement amounts to PayEdge for bank disbursement
PAYEDGE_BASE_URL=https://api.payedge.com.pk/v1
PAYEDGE_API_KEY=
PAYEDGE_COMPANY_ID=

# ── Bata Integration ──────────────────────────────────────────────────────────
# Bata ERP connection for syncing style SKUs and production targets
BATA_API_BASE_URL=https://erp.bata.com/api
BATA_API_KEY=
BATA_SYNC_SECRET=

# ── WhatsApp Notifications ────────────────────────────────────────────────────
# WhatsApp Business API for sending pay slips to workers
WHATSAPP_API_URL=https://api.whatsapp.com/v1
WHATSAPP_API_TOKEN=
WHATSAPP_FROM_NUMBER=
